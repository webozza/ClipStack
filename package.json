{
  "name": "clip-history-electron",
  "version": "1.0.0",
  "description": "A beautiful and powerful clipboard history manager for macOS.",
  "author": "Syed",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --watch . --ext js,html,css --exec \"electron .\"",
    "build": "electron-builder",
    "dist": "electron-builder",
    "build:mas": "CLIPSTACK_TARGET=mas electron-builder --mac mas"
  },
  "build": {
    "appId": "com.syed.clipboard",
    "productName": "ClipStack",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "mas": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "hardenedRuntime": false,
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "provisioningProfile": "build/embedded.provisionprofile"
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "directories": {
      "output": "dist"
    },
    "compression": "maximum"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.1.9",
    "playwright": "^1.59.1"
  }
}
